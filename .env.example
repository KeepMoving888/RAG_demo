# ==================== 通用配置（本地 + Streamlit Cloud） ====================
# 文档目录默认为 ./data/documents（代码已内置）
# 向量库目录默认为 ./data/chroma_db（代码已内置）

# ===== 嵌入模型配置 =====
# 本地离线：把模型放到 ./models/bge-m3
# EMBEDDING_MODEL=./models/bge-m3

# 云端在线：改为在线 embedding 模型（在 Streamlit Secrets 中配置）
# EMBEDDING_MODEL=text-embedding-v3
# EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_API_KEY=your_api_key

# ===== LLM 配置 =====
# 本地离线示例（本地 OpenAI 兼容服务）
# LLM_API_BASE=http://127.0.0.1:8000/v1
# LLM_MODEL=qwen2.5-7b-instruct
# LLM_API_KEY=not-needed

# 云端在线示例（DashScope OpenAI-compatible）
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen2.5-7b-instruct
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxx

# ===== 自动加载配置 =====
AUTO_INGEST=true
TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=100
SIMILARITY_THRESHOLD=0.7

# ==================== Streamlit Cloud Secrets 示例 ====================
# 在 Streamlit Cloud -> App -> Settings -> Secrets 中填写：
# STREAMLIT_CLOUD="true"
# LLM_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
# LLM_MODEL="qwen2.5-7b-instruct"
# LLM_API_KEY="your_api_key"
# EMBEDDING_MODEL="text-embedding-v3"
# EMBEDDING_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
# EMBEDDING_API_KEY="your_api_key"
# AUTO_INGEST="true"
